{
  "$schema": "https://railway.app/railway.schema.json",
  "build": { "builder": "NIXPACKS" },
  "deploy": {
    "preDeployCommand": "python manage.py migrate --noinput && python manage.py seed_articles",
    "startCommand": "gunicorn config.wsgi --bind 0.0.0.0:$PORT --workers 3 --timeout 60",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
